# Frontend
VITE_API_BASE_URL=http://localhost:4000
# Absolute origin for Open Graph / canonical (no trailing slash). Définir en prod/staging dans l’hébergeur ; défaut local ci-dessous.
VITE_SITE_ORIGIN=http://127.0.0.1:5173

# Backend
DATABASE_URL=postgres://postgres:postgres@localhost:5432/project_k
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@usestakly.local
DEV_USER_USERNAME=usestakly-dev
DEV_USER_DISPLAY_NAME="UseStakly Dev"
DEV_USER_AVATAR_URL=
APP_ENV=development
APP_BASE_URL=http://localhost:4000
FRONTEND_BASE_URL=http://localhost:5173
APP_SESSION_SECRET=change-me-to-a-long-random-string
# Dedicated encryption secret for notification destinations such as Discord webhooks.
# Use a different long random value from APP_SESSION_SECRET in production.
APP_NOTIFICATION_SECRET=change-me-to-another-long-random-string
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# GitHub Personal Access Token for repo ingestion (R1).
# Scope: public_repo (read-only on public repos is enough). Keep it out of git.
GITHUB_TOKEN=

# Scheduler (R3 cron) — refresh daily des repos watchés + corpus GitHub stale (>24 h), recompute scores + emit notifs.
# Opt-in explicite : laisser 'false' en dev local, activer en prod/staging.
APP_SCHEDULER_ENABLED=false
# Intervalle entre deux cycles, en secondes. Default 86400 (24 h). Min 60.
APP_RECOMPUTE_INTERVAL_SECS=86400
# Intervalle de vérification des résumés quotidiens, en secondes. Default 1800 (30 min). Min 60.
APP_DIGEST_INTERVAL_SECS=1800

# MCP write tools hardening (R5b)
# Limite par IP pour les requêtes /mcp sans token, mal formées ou avec token invalide.
APP_MCP_AUTH_FAILURE_LIMIT_PER_MINUTE=30
# Limite par token valide pour les reads /mcp (initialize/tools/list/search/context/recommend).
APP_MCP_READ_LIMIT_PER_MINUTE=120
# Quota cumulé par token sur log_usage + watch_repo + watch_use_case.
APP_MCP_WRITE_LIMIT_PER_HOUR=60
# Anti-doublon pour un même outcome sur un même repo via le même token.
APP_MCP_LOG_USAGE_COOLDOWN_SECS=900
# Fenêtre minimale entre deux outcomes négatifs sur un même repo pour un même user.
APP_MCP_NEGATIVE_SIGNAL_WINDOW_HOURS=24

# Active repo signals hardening (R4/R5b)
APP_ACTIVE_SIGNAL_MIN_REPUTATION=0.45
APP_ACTIVE_SIGNAL_DEFAULT_CONSENSUS=2
APP_ACTIVE_SIGNAL_SEVERE_CONSENSUS=3

# Semantic search (R2b)
# Local embeddings via fastembed + pgvector ranking blend.
APP_SEMANTIC_SEARCH_ENABLED=false

RUST_LOG=info
